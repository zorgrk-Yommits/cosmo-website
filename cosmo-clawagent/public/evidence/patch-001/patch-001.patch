+// The RPC strips leading zeros from addresses (0x0a05.. comes back as
+// 0xa05..), while gate configs are hand-maintained in the canonical 64-hex
+// form. Canonicalize to lowercase 0x + 64 hex chars so both forms of the
+// same address compare equal; non-hex input keeps its lowercased form and
+// can then only ever hit the default-reject path (no new throw surface).
 function normAddr(a: string): string {
-  return a.toLowerCase().startsWith("0x") ? a.toLowerCase() : `0x${a.toLowerCase()}`;
+  const lower = a.toLowerCase();
+  const hex = lower.startsWith("0x") ? lower.slice(2) : lower;
+  if (!/^[0-9a-f]{1,64}$/.test(hex)) return lower;
+  return `0x${hex.padStart(64, "0")}`;
 }
 
